# ===========================================
# Social Media Scraper - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values.

# --- YouTube ---
YOUTUBE_API_KEY=your_youtube_api_key_here
YOUTUBE_SEARCH_QUERIES=python tutorial,machine learning
YOUTUBE_MAX_RESULTS=10

# --- Twitter / X ---
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here
TWITTER_SEARCH_QUERIES=AI,python
TWITTER_TWEET_COUNT=100
WEBSCRAPING_AI_KEY=your_webscraping_ai_key_here

# --- Instagram ---
INSTAGRAM_TARGETS=natgeo,nasa
INSTAGRAM_PROXY=

# --- Scheduler ---
SCRAPE_INTERVAL_MINUTES=60

# --- MongoDB (optional) ---
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=social_scraper

# --- Browser ---
HEADLESS=true

# --- Export ---
EXPORT_FORMAT=json
